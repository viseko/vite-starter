mixin page-footer(data={})
  footer.page-footer(
    class=data.className,
    class=(data.theme ? `page-footer--theme--${data.theme}` : null),
    class=(data.size ? `page-footer--size--${data.size}` : null),
    data-role=data.role,
  )
    .container
      .flex-row.justify-between.gap-3
        +footer-copy
        +footer-dev
