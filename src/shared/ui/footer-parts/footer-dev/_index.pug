mixin footer-dev(data={})
  .footer-dev(
    class=data.className,
    class=(data.theme ? `footer-dev--theme--${data.theme}` : null),
    class=(data.size ? `footer-dev--size--${data.size}` : null),
    data-role=data.role,
  )
    .footer-dev__title Разработка сайта: 
    a.footer-dev__link(href="https://design-lab.ru" target="_blank" rel="noopener noreferrer") Design Lab